{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User business profile and subscription info",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique user identifier (UID)" },
        "email": { "type": "string", "description": "User email address" },
        "business_name": { "type": "string", "description": "Name of the business" },
        "business_type": { "type": "string", "description": "Industry or business model" },
        "plan": { "type": "string", "description": "Subscription plan (free, starter, pro, agency)" },
        "replies_used": { "type": "integer", "description": "Count of AI replies consumed in current cycle" },
        "replies_limit": { "type": "integer", "description": "Total allowed replies under the plan" },
        "razorpay_subscription_id": { "type": "string", "description": "Active Razorpay subscription token" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation time of profile" }
      },
      "required": ["id", "email"]
    },
    "ReviewHistory": {
      "title": "ReviewHistory",
      "description": "Historical record of review text and generated replies",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Document identifier" },
        "user_id": { "type": "string", "description": "Reference to the UserProfile" },
        "review_text": { "type": "string", "description": "Original customer review or voice dictation draft" },
        "reply_text": { "type": "string", "description": "AI-generated response text" },
        "tone": { "type": "string", "description": "Vibe tone chosen" },
        "language": { "type": "string", "description": "Target response language" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of record entry" }
      },
      "required": ["user_id", "review_text", "reply_text"]
    }
  },
  "firestore": {
    "/users_profile/{userId}": {
      "schema": "UserProfile",
      "description": "Individual business settings and subscription limits"
    },
    "/users_profile/{userId}/history/{reviewId}": {
      "schema": "ReviewHistory",
      "description": "List of responses generated by the user"
    }
  }
}
